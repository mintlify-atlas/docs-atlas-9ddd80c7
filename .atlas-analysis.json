  "keyFeatures": [
    "Type-driven development with automatic validation using Python type hints",
    "Automatic interactive API documentation (Swagger UI and ReDoc)",
    "High performance - comparable to NodeJS and Go frameworks",
    "Built-in dependency injection system for shared logic and resources",
    "OAuth2 and JWT authentication with security utilities",
    "Full async/await support with sync function compatibility",
    "Pydantic-powered request and response validation",
    "Automatic OpenAPI 3.1.0 schema generation",
    "WebSocket and Server-Sent Events support",
    "Production-ready with testing utilities and deployment guides"
  ],
  "publicApiSurface": [
    "FastAPI - Main application class",
    "APIRouter - Modular routing system",
    "Request - HTTP request object",
    "Response - HTTP response classes",
    "WebSocket - WebSocket connection handling",
    "Path - Path parameter declaration",
    "Query - Query parameter declaration",
    "Body - Request body declaration",
    "Header - Header parameter declaration",
    "Cookie - Cookie parameter declaration",
    "Form - Form data declaration",
    "File - File upload declaration",
    "Depends - Dependency injection",
    "Security - Security dependency utilities",
    "HTTPException - HTTP exception handling",
    "BackgroundTasks - Background task execution",
    "UploadFile - File upload handling",
    "status - HTTP status code constants",
    "OAuth2PasswordBearer - OAuth2 password flow",
    "OAuth2PasswordRequestForm - OAuth2 form data",
    "HTTPBasic - HTTP Basic authentication",
    "HTTPBearer - HTTP Bearer token authentication",
    "APIKeyHeader - API key in header",
    "APIKeyQuery - API key in query parameter",
    "APIKeyCookie - API key in cookie",
    "CORSMiddleware - Cross-origin resource sharing",
    "GZipMiddleware - Response compression",
    "TestClient - Testing utility client",
    "JSONResponse - JSON response class",
    "HTMLResponse - HTML response class",
    "StreamingResponse - Streaming response class",
    "FileResponse - File download response",
    "RedirectResponse - Redirect response",
    "EventSourceResponse - Server-Sent Events response"
  ]
}
